      "id": "arch-micro-02",
      "category": "architecture",
      "difficulty": "medium",
      "prompt": "이커머스 마이크로서비스 아키텍처: API 게이트웨이, 주문·결제·재고 서비스, 각자 전용 DB, 서비스 간 비동기 통신은 Kafka.",
      "expected": {
        "node_count": { "min": 8, "max": 14 },
        "edge_count": { "min": 7, "max": 16 },
        "required_concepts": ["게이트웨이", "주문", "결제", "재고", "Kafka"]
      }
    },
    {
