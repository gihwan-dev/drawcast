{
  "$schema": "./schemas/question.schema.json",
  "version": "0.1.0",
  "questions": [
    {
      "id": "flow-login-01",
      "category": "flowchart",
      "difficulty": "easy",
      "prompt": "사용자 로그인 과정을 플로우차트로 그려줘. 이메일/비밀번호 입력, 검증, 성공/실패 분기를 포함할 것.",
      "expected": {
        "node_count": { "min": 5, "max": 9 },
        "edge_count": { "min": 4, "max": 10 },
        "required_concepts": ["로그인", "검증", "성공", "실패"],
        "must_have_branch": true
      },
      "rubric_weights": { "structure": 1.2, "intent_fit": 1.2 },
      "notes": "성공/실패 두 분기가 명확히 보여야 함"
    },
    {
      "id": "flow-signup-02",
      "category": "flowchart",
      "difficulty": "medium",
      "prompt": "회원가입 + 이메일 인증 플로우를 그려줘. 약관 동의, 이메일 중복 체크, 인증 메일 발송, 링크 클릭, 계정 활성화까지 포함.",
      "expected": {
        "node_count": { "min": 8, "max": 14 },
        "edge_count": { "min": 7, "max": 15 },
        "required_concepts": ["약관", "중복", "이메일", "인증", "활성화"],
        "must_have_branch": true
      }
    },
    {
      "id": "flow-order-03",
      "category": "flowchart",
      "difficulty": "medium",
      "prompt": "이커머스 주문 처리 플로우: 장바구니 → 주문 생성 → 결제 → 결제 성공/실패 → 재고 차감 → 배송 시작.",
      "expected": {
        "node_count": { "min": 8, "max": 14 },
        "edge_count": { "min": 7, "max": 15 },
        "required_concepts": ["장바구니", "주문", "결제", "재고", "배송"],
        "must_have_branch": true
      }
    },
    {
      "id": "flow-ci-04",
      "category": "flowchart",
      "difficulty": "hard",
      "prompt": "GitHub PR이 만들어진 후부터 main에 머지될 때까지의 CI/CD 파이프라인을 그려줘. 린트, 타입체크, 단위 테스트, 빌드, 통합 테스트, 배포 승인, 스테이징 배포, 프로덕션 배포까지 순서대로. 실패 시 어디로 가는지도.",
      "expected": {
        "node_count": { "min": 10, "max": 18 },
        "edge_count": { "min": 10, "max": 22 },
        "required_concepts": ["PR", "린트", "타입", "테스트", "빌드", "스테이징", "프로덕션", "승인"],
        "must_have_branch": true
      }
    },
    {
      "id": "flow-retry-05",
      "category": "flowchart",
      "difficulty": "easy",
      "prompt": "API 호출에 지수 백오프 재시도를 적용한 플로우차트. 실패 시 대기 후 재시도, 최대 N회까지.",
      "expected": {
        "node_count": { "min": 4, "max": 8 },
        "edge_count": { "min": 4, "max": 9 },
        "required_concepts": ["호출", "실패", "대기", "재시도", "최대"],
        "must_have_branch": true,
        "must_have_loop": true
      }
    },
    {
      "id": "arch-3tier-01",
      "category": "architecture",
      "difficulty": "easy",
      "prompt": "전형적인 3계층 웹 아키텍처를 그려줘. 프론트엔드(브라우저) - 백엔드(API 서버) - 데이터베이스.",
      "expected": {
        "node_count": { "min": 3, "max": 6 },
        "edge_count": { "min": 2, "max": 6 },
        "required_concepts": ["프론트", "백엔드", "데이터베이스"]
      }
    },
