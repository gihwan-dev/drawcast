{
  "name": "@drawcast/app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "predev": "pnpm --filter @drawcast/mcp-server build && pnpm build:sidecar",
