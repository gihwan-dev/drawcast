{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/drawcast-mcp",
          "sidecar": true,
          "args": [
            "--sse",
            "--port",
            { "validator": "^(auto|\\d+)$" },
            "--session-path",
            { "validator": ".+" }
          ]
        }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default"
  ]
}
