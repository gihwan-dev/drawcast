{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drawcast",
  "version": "0.0.0",
  "identifier": "com.drawcast.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Drawcast",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/drawcast-mcp"],
    "macOS": {
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "hardenedRuntime": true
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/drawcast-mcp",
          "sidecar": true,
          "args": [
            "--sse",
            "--port",
            { "validator": "^(auto|\\d+)$" },
            "--session-path",
            { "validator": ".+" }
          ]
        }
      ]
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/<OWNER>/drawcast/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "<FILL IN PUBLIC KEY AT RELEASE TIME>"
    }
  }
}
