{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drawcast",
  "version": "0.0.0",
  "identifier": "com.drawcast.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Drawcast",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/drawcast-mcp"],
    "macOS": {
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "hardenedRuntime": true
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/gihwan-dev/drawcast/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCOTJCRjMwM0I3QUJDQjAKUldTd3ZIbzdNTCtTaTdSSGp0RnNsdlc4b1VYNFhibW5tOWlXenJENjNpemhVZ0JCNlVQRENpTU0K"
    }
  }
}
